<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1">
  <dashboard-extension id="com.cwtwb.dashboard-builder" extension-version="0.1.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name">cwtwb Dashboard Builder</name>
    <description>Generate Tableau dashboards from connected data using AI-powered suggestions</description>
    <author name="cwtwb" email="cwtwb@example.com" organization="cwtwb" website="https://github.com/imgwho/cwtwb"/>
    <min-api-version>1.7</min-api-version>
    <source-location>
      <url>http://localhost:8000</url>
    </source-location>
    <icon></icon>
    <permissions>
      <permission>full data</permission>
    </permissions>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">cwtwb Dashboard Builder</text>
    </resource>
  </resources>
</manifest>
