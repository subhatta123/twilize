            <collation flag='1' name='LEN_RGB_S2' />
            <attributes>
              <attribute datatype='string' name='DebugRemoteType'>&quot;WSTR&quot;</attribute>
            </attributes>
            <object-id>[Returns_58BFE7A0D587401EB95F460C45AE5B32]</object-id>
          </metadata-record>
        </metadata-records>
      </connection>
      <aliases enabled='yes' />
      <column caption='% Not Returned' datatype='real' name='[% Returned (copy)_1828461467462164486]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1-COUNTD([Calculation_1828461467461767171])&#13;&#10;/&#13;&#10;COUNTD([Order ID])' />
      </column>
      <column caption='Time' datatype='integer' name='[Calculation_1828461467459371008]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Order Date], [Dispatch Date])' />
      </column>
      <column caption='Number Furniture' datatype='string' name='[Calculation_1828461467461767171]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Category] = &apos;Furniture&apos; THEN [Order ID] END' />
      </column>
      <column caption='% Returned' datatype='real' name='[Calculation_1828461467461914629]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Calculation_1828461467461767171])&#13;&#10;/&#13;&#10;COUNTD([Order ID])' />
      </column>
      <column caption='% to Target' datatype='real' name='[Calculation_1828461467464024073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])&#13;&#10;/&#13;&#10;[Parameters].[Parameter 3]' />
      </column>
      <column caption='Profit Ratio' datatype='real' default-format='p0%' name='[Calculation_5571209093911105]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' scope-isolation='false' />
      </column>
      <column caption='Selected Country' datatype='boolean' name='[Calculation_798826002888744962]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Country/Region]=[Parameters].[Country/Region Parameter]' />
      </column>
      <column caption='Target Hit?' datatype='string' name='[Calculation_798826002911879188]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1828461467464024073] &gt; 1 THEN &apos;Yes&apos; ELSE &apos;No&apos; END' />
      </column>
      <column caption='Sales Over 400' datatype='string' name='[Calculation_798826002913071125]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Sales]) &gt; 500 THEN &apos;Yes&apos; ELSE &apos;No&apos; END' />
      </column>
      <column datatype='string' name='[Category]' role='dimension' type='nominal' />
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column datatype='string' name='[Country/Region]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
