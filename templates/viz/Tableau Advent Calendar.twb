      <column datatype='string' name='[Customer Name]' role='dimension' type='nominal' />
      <column datatype='real' default-format='p0%' name='[Discount]' role='measure' type='quantitative' />
      <column caption='Number Not Returned' datatype='string' name='[Number Returned (copy)_1828461467461869572]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Category] != &apos;Furniture&apos; THEN [Order ID] END' />
      </column>
