      <aliases enabled="yes"/>
      <column caption="Profit Ratio" datatype="real" name="[Calculation_1368249927221915648]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Profit])/SUM([Sales])"/>
      </column>
      <column caption="Most Recent Date" datatype="date" name="[Calculation_2370089732827549697]" role="dimension" type="ordinal">
        <calculation class="tableau" formula="{MAX([Order Date])}"/>
      </column>
      <column caption="Sales | YTD" datatype="real" default-format="c&quot;$&quot;#,##0;-&quot;$&quot;#,##0" name="[Calculation_2370089732827709442]" role="measure" type="quantitative">
        <calculation class="tableau" formula="IF [Order Date] &lt;= [Calculation_2370089732827549697]&#10;AND [Order Date] &gt;= DATETRUNC('year',[Calculation_2370089732827549697])&#10;THEN [Sales]&#10;END"/>
      </column>
      <column caption="Sales | Red Dot | YTD &gt; LYTD" datatype="string" name="[Calculation_2370089732830470151]" role="measure" type="nominal">
        <calculation class="tableau" formula="IF [Sales | YTD (copy)_2370089732829294598] &lt; 0&#10;THEN '●'&#10;ELSE ''&#10;END"/>
      </column>
      <column caption="min (0.0)" datatype="real" name="[Calculation_2370089732838391825]" role="measure" type="quantitative">
        <calculation class="tableau" formula="MIN(0.0)"/>
      </column>
      <column caption="min (1.0)" datatype="real" name="[Calculation_2370089732838432786]" role="measure" type="quantitative">
        <calculation class="tableau" formula="MIN(1.0)"/>
      </column>
      <column caption="TF | Exclude 12/31/2023" datatype="boolean" name="[Calculation_2910380958065635360]" role="dimension" type="nominal">
        <calculation class="tableau" formula="[Order Date] != DATE('2023-12-31')"/>
      </column>
      <column caption="Sales | PM" datatype="real" name="[Calculation_4235002193149915136]" role="measure" type="quantitative">
        <calculation class="tableau" formula="IF [Order Date] &lt;= DATEADD('month',-1,[Calculation_2370089732827549697])&#10;AND [Order Date] &gt;= DATETRUNC('month',DATEADD('month',-1,[Calculation_2370089732827549697]))&#10;THEN [Sales]&#10;END"/>
      </column>
      <column caption="Sales | Lookup PM" datatype="real" name="[Calculation_4235002193154822155]" role="measure" type="quantitative">
        <calculation class="tableau" formula="LOOKUP(SUM([Sales]),-1)">
          <table-calc ordering-type="Rows"/>
        </calculation>
      </column>
      <column caption="Sales | Tier | Above/Below PM" datatype="string" name="[Calculation_4235002193155088396]" role="measure" type="nominal">
        <calculation class="tableau" formula="IF SUM([Sales]) &gt;= [Calculation_4235002193154822155]&#10;THEN 'Above PM'&#10;ELSEIF SUM([Sales]) &lt; [Calculation_4235002193154822155]&#10;THEN 'Below PM'&#10;END">
          <table-calc ordering-type="Rows"/>
        </calculation>
      </column>
      <column caption="Sales | Text | Above MoM" datatype="real" default-format="*▲ 0.0%;▼ 0.0%" name="[Calculation_4499447934109188097]" role="measure" type="quantitative">
        <calculation class="tableau" formula="IF [Sales | Diff % CM vs LYCM (copy)_4235002193150181377] &gt; 0&#10;THEN [Sales | Diff % CM vs LYCM (copy)_4235002193150181377]&#10;END"/>
      </column>
      <column caption="Filter | Last &lt;= 10" datatype="boolean" name="[Calculation_4499447934112215052]" role="measure" type="nominal">
        <calculation class="tableau" formula="LAST() &lt;= 11">
          <table-calc ordering-type="Rows"/>
        </calculation>
      </column>
      <column caption="Sales | LYFM" datatype="real" name="[Calculation_4499447934116470801]" role="measure" type="quantitative">
        <calculation class="tableau" formula="IF DATEPART('year',[Order Date]) = DATEPART('year',[Calculation_2370089732827549697]) - 1&#10;AND DATEPART('month',[Order Date]) = DATEPART('month',[Calculation_2370089732827549697])&#10;THEN [Sales]&#10;END"/>
      </column>
      <column caption="Sales | Diff % MTD vs LYMTD" datatype="real" default-format="*+0.0%;-0.0%" name="[Calculation_4499447934118318103]" role="measure" type="quantitative">
        <calculation class="tableau" formula="(SUM([Sales | LYTD (copy)_2370089732836651022]) - SUM([Sales | CM (copy)_4499447934116937746]))&#10;/&#10;SUM([Sales | CM (copy)_4499447934116937746])"/>
      </column>
      <column caption="Sales | Running | MTD Hidden" datatype="real" name="[Calculation_4499447934122164249]" role="measure" type="quantitative">
        <calculation class="tableau" formula="IF MAX(DATEPART('day',[Order Date])) &lt;= MAX(DATEPART('day',[Calculation_2370089732827549697]))&#10;THEN RUNNING_SUM(SUM([Sales | LYTD (copy)_2370089732836651022]))&#10;END">
          <table-calc ordering-type="Rows"/>
        </calculation>
      </column>
      <column caption="Most Recent Date | Day" datatype="integer" name="[Calculation_4499447934123393053]" role="measure" type="quantitative">
        <calculation class="tableau" formula="DATEPART('day',[Calculation_2370089732827549697])"/>
      </column>
      <column caption="Sales | Fixed | Diff % MTD vs LYMTD" datatype="real" name="[Calculation_4499447934124306464]" role="measure" type="quantitative">
        <calculation class="tableau" formula="{ FIXED :[Calculation_4499447934118318103]}"/>
      </column>
