              <calculation class='tableau' formula='(SUM([Calculation_7CDFD6054558462D9A7A82D78CFC3575]) - SUM([Calculation_83F7B0FB37AF46178E33A9B178832EB1])) / SUM([Calculation_83F7B0FB37AF46178E33A9B178832EB1])' />
